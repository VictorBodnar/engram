{
  "_note": "Reference only. Hooks are registered directly in ~/.claude/settings.json by manage.py install. This file documents the hook events Engram uses.",
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "python3 \"/path/to/engram/scripts/session_start.py\" # engram-managed-hook", "timeout": 10 } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "python3 \"/path/to/engram/scripts/user_prompt.py\" # engram-managed-hook", "timeout": 10 } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "python3 \"/path/to/engram/scripts/stop_distill.py\" # engram-managed-hook", "timeout": 10 } ] }
    ],
    "PreCompact": [
      { "hooks": [ { "type": "command", "command": "python3 \"/path/to/engram/scripts/precompact.py\" # engram-managed-hook", "timeout": 10 } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "python3 \"/path/to/engram/scripts/session_end.py\" # engram-managed-hook", "timeout": 10 } ] }
    ]
  }
}
